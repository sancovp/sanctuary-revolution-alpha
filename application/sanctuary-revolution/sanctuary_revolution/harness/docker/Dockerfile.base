# PAIA Agent Container
# Base image with Claude CLI + handoff server + tmux for key sending

FROM python:3.11-slim

# Install Node.js for Claude CLI + tmux for key control
RUN apt-get update && apt-get install -y \
    curl \
    bash \
    tmux \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Claude CLI
RUN npm install -g @anthropic-ai/claude-code

# Install Python dependencies for handoff server
COPY requirements.txt /tmp/
RUN pip install --no-cache-dir -r /tmp/requirements.txt

# Copy handoff server and entrypoint
COPY container_handoff.py /usr/local/bin/handoff_server.py
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# Setup agent directory
RUN mkdir -p /agent/.claude /shared

WORKDIR /agent

# Entrypoint starts tmux + handoff server
CMD ["/usr/local/bin/entrypoint.sh"]
