        <rdfs:comment>Skill with category=Preflight MUST have partOf GIINT_Component/Feature OR hasDescribesComponent GIINT_Component.</rdfs:comment>
    </owl:Class>

    <!-- STP Skill: MUST have partOf GIINT_*, hasProduces GIINT_Deliverable, OR hasDescribesComponent GIINT_Component -->
    <owl:Class rdf:about="#Single_Turn_Process_Skill">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
