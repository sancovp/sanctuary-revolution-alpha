    <!-- ============================================== -->

    <!-- Understand Skill: MUST have hasDescribesComponent → GIINT_Component -->
    <owl:Class rdf:about="#Understand_Skill">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="#Skill"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="#hasCategory"/>
                        <owl:hasValue rdf:resource="#Skill_Category_Understand"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#hasDescribesComponent"/>
                <owl:someValuesFrom rdf:resource="#GIINT_Component"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>Understand Skill</rdfs:label>
        <rdfs:comment>Skill with category=Understand MUST have hasDescribesComponent pointing to a GIINT_Component.</rdfs:comment>
    </owl:Class>

    <!-- Preflight Skill: MUST have partOf GIINT_Component/Feature OR hasDescribesComponent GIINT_Component -->
    <owl:Class rdf:about="#Preflight_Skill">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="#Skill"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="#hasCategory"/>
                        <owl:hasValue rdf:resource="#Skill_Category_Preflight"/>
