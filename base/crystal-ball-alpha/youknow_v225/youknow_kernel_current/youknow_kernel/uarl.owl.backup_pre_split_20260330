        </rdfs:subClassOf>
        <rdfs:label>Single Turn Process Skill</rdfs:label>
        <rdfs:comment>Skill with category=STP MUST have one of: partOf GIINT_Component/Feature, hasProduces GIINT_Deliverable, or hasDescribesComponent GIINT_Component.</rdfs:comment>
