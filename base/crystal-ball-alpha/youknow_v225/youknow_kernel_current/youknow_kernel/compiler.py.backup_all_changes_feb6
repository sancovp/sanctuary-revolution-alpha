@dataclass
class ParsedStatement:
    """A parsed YOUKNOW statement.

    REAL: Basic regex parsing works.
    TODO: Handle complex statements (multiple predicates, nested structures).
    """
    subject: str
    predicate: str  # is_a, part_of, instantiates, has_part, etc.
    object: str

    # Additional predicates in same statement
    # e.g., "Animal is_a Entity, part_of Living_Things, instantiates Creature"
    additional: List[Tuple[str, str]] = field(default_factory=list)

    raw: str = ""


def parse_statement(statement: str) -> Optional[ParsedStatement]:
    """Parse a YOUKNOW statement.

    REAL: Basic pattern matching.

    WEAK COMPRESSION: Unknown predicates are accepted and marked for SOUP.
    They need their own derivation chains to become strong compression.

    Examples:
        "Dog is_a Animal" → ParsedStatement(Dog, is_a, Animal)
        "Dog has_trait Loyalty" → ParsedStatement(Dog, has_trait, Loyalty) [weak compression]
    """
    statement = statement.strip()

    # STRONG compression predicates (in foundation ontology)
    STRONG_PREDICATES = {'is_a', 'part_of', 'instantiates', 'has_part', 'embodies', 'manifests', 'reifies'}

    # Pattern: Subject predicate Object
    # Accept ANY word as predicate (weak compression if not in STRONG_PREDICATES)
    primary_match = re.match(
        r'(\w+)\s+(\w+)\s+(\w+)',
        statement,
        re.IGNORECASE
    )

    if not primary_match:
        return None

    subject = primary_match.group(1)
    predicate = primary_match.group(2).lower()
    obj = primary_match.group(3)

    # Look for additional predicates (comma-separated)
    additional = []
    rest = statement[primary_match.end():]

    for match in re.finditer(r',\s*(\w+)\s+(\w+)', rest, re.IGNORECASE):
        additional.append((match.group(1).lower(), match.group(2)))

    return ParsedStatement(
        subject=subject,
        predicate=predicate,
        object=obj,
        additional=additional,
        raw=statement
    )


