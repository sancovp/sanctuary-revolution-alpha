def youknow(statement: str, use_reasoner: bool = True) -> str:
    """THE entry point. Pure function. Stateless.

    VALIDATION PIPELINE:
        1. Parse statement
        2. Build spiral (HyperedgeValidator for EMR)
        3. Check chain completeness (Python dict traversal)
        4. [NEW] Reasoner validation (SHACL + Pellet)
        5. Return OK/Wrong with because()

    Args:
        statement: Any YOUKNOW statement, e.g., "Dog is_a Animal"
        use_reasoner: Whether to run SHACL + Pellet validation (default: True)

    Returns:
        "You said X. {OK|Wrong} because {because()}"
    """
    # 1. Parse the statement
    parsed = parse_statement(statement)
    if not parsed:
        return f"You said {statement}. Wrong because: could not parse statement."

    # 1b. Check for WEAK COMPRESSION predicates
    # Strong predicates are in foundation ontology, weak need their own derivation chains
    STRONG_PREDICATES = {'is_a', 'part_of', 'instantiates', 'has_part', 'embodies', 'manifests', 'reifies'}

    if parsed.predicate not in STRONG_PREDICATES:
        # Weak compression - predicate itself needs derivation chain → SOUP
        pred_missing = [
            f"{parsed.predicate} is_a ? (unknown)",
            f"{parsed.predicate} part_of ? (unknown)",
            f"{parsed.predicate} instantiates ? (unknown)"
        ]
        # Persist predicate as Hallucination
        all_missing = pred_missing + [f"{parsed.object} is_a ? (unknown)"]
        _persist_to_soup(parsed, [], parsed.predicate, all_missing)
        # Build response with full state for weak compression path
        weak_response = CompilerResponse(
            statement=statement,
            response_type=ResponseType.WRONG,
            spiral=[],
            break_point=parsed.predicate,
            whats_missing=all_missing
        )
        return _build_soup_response(weak_response, [], parsed.predicate, all_missing)

    # 2. Build the spiral (uses HyperedgeValidator for EMR)
    spiral = _build_spiral(parsed)

    # 3. Check if chain is complete (Python dict traversal)
    is_complete, break_point, whats_missing = _check_chain_complete(spiral)

    # 4. [NEW] Reasoner validation - SHACL for structure, Pellet for inference
    if is_complete and use_reasoner:
        reasoner_result = _validate_with_reasoner(parsed, spiral)
        if not reasoner_result["valid"]:
            is_complete = False
            whats_missing = reasoner_result["errors"]
            break_point = reasoner_result.get("break_point", parsed.subject)

    # 5. Build response
    response = CompilerResponse(
        statement=statement,
        response_type=ResponseType.OK if is_complete else ResponseType.WRONG,
        spiral=spiral,
        break_point=break_point,
        whats_missing=whats_missing
    )

    # 6. Persist based on completeness level
    #
    # METACIRCULAR SOUP ACCUMULATION (IMPLEMENTED)
    # =============================================
    # Errors are not failures - they are TYPED PUZZLE PIECES (Hallucinations).
    #
    # When chain breaks at X:
    #   - Create Hallucination with metadata (what's missing)
    #   - Persist to SOUP layer
    #   - Return "SOUP: ..." instead of "Wrong..."
    #
    # When chain completes:
    #   - Persist to ONT layer (domain OWL)
    #   - Return "OK"
    #
    if is_complete:
        _persist(parsed, spiral)
        return response.to_string()  # "OK"
    else:
        # Chain breaks - persist to SOUP with Hallucination metadata
        hallucination_meta = _persist_to_soup(parsed, spiral, break_point, whats_missing)

        # Return full state: spiral with derivation levels + what to declare next
        return _build_soup_response(response, spiral, break_point, whats_missing)


def _validate_with_reasoner(parsed: 'ParsedStatement', spiral: List[SpiralStep]) -> dict:
    """Run SHACL + Pellet validation on the parsed statement.

    Pipeline:
        1. SHACL validates structure (EMR components present)
        2. Pellet validates reasoning (transitive chain reaches Cat_of_Cat)

    Returns:
        {"valid": bool, "errors": List[str], "break_point": Optional[str]}
    """
    from .uarl_validator import UARLValidator

    try:
        validator = UARLValidator()

        # Build concept data from parsed statement
        concept_data = {
            "name": parsed.subject,
            "type": "EmbodimentClaim",  # TODO: Infer type from predicate
            "intuition": parsed.subject,
            "compareFrom": parsed.predicate,
            "mapsTo": parsed.object,
            "analogicalPattern": f"{parsed.subject}_{parsed.predicate}_{parsed.object}_pattern"
        }

        # Run SHACL + Pellet validation
        # NOTE: No check_chain_to - Python handles Cat_of_Cat traversal,
        # reasoner validates axiom satisfaction (EmbodimentClaim properties)
        result = validator.validate_with_reasoning(concept_data)

        if result.valid:
            return {"valid": True, "errors": [], "break_point": None}
        else:
            return {
                "valid": False,
                "errors": [e.message for e in result.errors],
                "break_point": parsed.subject
            }

    except Exception as e:
        # Reasoner unavailable - log but don't block
        # TODO: Add proper logging
        return {
            "valid": True,  # Pass through if reasoner fails
            "errors": [f"Reasoner warning: {e}"],
            "break_point": None
        }


def _build_spiral(parsed: ParsedStatement) -> List[SpiralStep]:
    """Build the derivation spiral for a statement.

    Uses REAL validators:
        - HyperedgeValidator for EMR (embodies/manifests/reifies)
        - DerivationValidator for L0-L6 levels
        - Cat_of_Cat for chain tracing
    """
    from .cat_of_cat import get_cat
    from .hyperedge import HyperedgeValidator
    from .derivation import DerivationValidator

    cat = get_cat()
    hyperedge_validator = HyperedgeValidator(cat=cat)
    derivation_validator = DerivationValidator(cat=cat)

    spiral = []

    # Step 1: Validate the claim itself using HyperedgeValidator
    # Build concept dict for the subject
    subject_concept = None
    if parsed.subject in cat.entities:
        entity = cat.entities[parsed.subject]
        subject_concept = {
            "name": entity.name,
            "is_a": entity.is_a,
            "part_of": entity.part_of,
            "has_part": entity.has_part,
            "instantiates": entity.instantiates,
        }

    # If subject not in ontology, create minimal concept dict
    if subject_concept is None:
        subject_concept = {
            "name": parsed.subject,
            "is_a": [parsed.object],
            "part_of": [],
            "has_part": [],
            "instantiates": [],
        }

    claim_result = hyperedge_validator.validate_claim(
        subject=parsed.subject,
        object_=parsed.object,
        concept=subject_concept
    )

    # Build concept dict for derivation validation
    concept_dict = {
        "name": parsed.subject,
        "is_a": [parsed.object],
        "part_of": [],
        "instantiates": [],
    }
    # Add additional predicates
    for pred, obj in parsed.additional:
        if pred == "part_of":
            concept_dict["part_of"].append(obj)
        elif pred == "instantiates":
            concept_dict["instantiates"].append(obj)

    derivation_state = derivation_validator.validate(concept_dict)

    spiral.append(SpiralStep(
        subject=parsed.subject,
        predicate=parsed.predicate,
        object=parsed.object,
        embodies=claim_result.supporting_evidence,
        manifests={},
        reifies_via=claim_result.witness,
        derivation_level=derivation_state.level,
        whats_missing_for_next_level=derivation_state.whats_missing,
        is_placeholder=not claim_result.valid
    ))

    # Step 2: Trace the object upward
    # TODO: Actually look up the object in the ontology
    # For now, create placeholder steps

    current = parsed.object

    # REAL: Use Cat_of_Cat.trace_to_root()
    chain = _get_chain(current)

    for i, (entity, parent) in enumerate(chain):
        is_defined = parent != "?"

        # Build concept dict for this chain entity
        if entity in cat.entities:
            chain_entity = cat.entities[entity]
            chain_concept = {
                "name": chain_entity.name,
                "is_a": chain_entity.is_a,
                "part_of": chain_entity.part_of,
                "has_part": chain_entity.has_part,
                "instantiates": chain_entity.instantiates,
            }
        else:
            chain_concept = {
                "name": entity,
                "is_a": [parent] if is_defined else [],
                "part_of": [],
                "instantiates": [],
            }

        # Get EMR from HyperedgeValidator
        chain_claim = hyperedge_validator.validate_claim(
            subject=entity,
            object_=parent,
            concept=chain_concept
        )

        # Get derivation state
        chain_deriv = derivation_validator.validate(chain_concept)

        spiral.append(SpiralStep(
            subject=entity,
            predicate="is_a",
            object=parent,
            embodies=chain_claim.supporting_evidence,
            manifests={},
            reifies_via=chain_claim.witness,
            derivation_level=chain_deriv.level,
            whats_missing_for_next_level=chain_deriv.whats_missing,
            is_placeholder=not is_defined
        ))

        if not is_defined:
            break  # Chain breaks here

    return spiral


def _get_chain(entity: str) -> List[Tuple[str, str]]:
    """Get is_a chain from Cat_of_Cat.

    REAL: Uses actual CategoryOfCategories.trace_to_root()
    """
    from .cat_of_cat import get_cat

    cat = get_cat()

    # Check if entity exists
    if entity not in cat.entities:
        return [(entity, "?")]  # Unknown entity

    # Get the chain
    chain = cat.trace_to_root(entity)

    # Convert to pairs: [(A, B), (B, C), ...]
    pairs = []
    for i in range(len(chain) - 1):
        pairs.append((chain[i], chain[i + 1]))

    # If chain ends at Cat_of_Cat, add final pair
    if chain and chain[-1] == "Cat_of_Cat":
        # Cat_of_Cat is_a Cat_of_Cat (self-loop, complete)
        pass
    elif chain:
        # Chain doesn't reach Cat_of_Cat
        pairs.append((chain[-1], "?"))

    return pairs if pairs else [(entity, "?")]


def _check_chain_complete(spiral: List[SpiralStep]) -> Tuple[bool, Optional[str], List[str]]:
    """Check if the spiral traces all the way to Cat_of_Cat.

    WHAT'S REAL:
        - Checks for placeholder steps

    WHAT'S TODO:
        - Use actual DerivationValidator
        - Check L0-L6 levels
        - Verify inclusion maps

    Returns:
        (is_complete, break_point, whats_missing)
    """
    for step in spiral:
        if step.is_placeholder:
            return (
                False,
                step.subject,
                [
                    f"{step.subject} is_a ? (unknown)",
                    f"{step.subject} part_of ? (unknown)",
                    f"{step.subject} instantiates ? (unknown)"
                ]
            )

    # Check if we reached Cat_of_Cat
    if spiral and spiral[-1].object == "Cat_of_Cat":
        return (True, None, [])

    return (
        False,
        spiral[-1].subject if spiral else "?",
        ["Chain does not reach Cat_of_Cat"]
    )


def _persist(parsed: ParsedStatement, spiral: List[SpiralStep]) -> None:
    """Persist valid statements to OWL + Carton via DualSubstrate.

    DualSubstrate pattern: OWL is source of truth, Carton is mirror.
    Valid chains go to ONT layer in both substrates.

    Args:
        parsed: The parsed statement
        spiral: The derivation spiral (enriches OWL entity with EMR data)
    """
    from .owl_substrate import DualSubstrate, OWLEntity

    try:
        dual = DualSubstrate()

        # Build relationships dict from parsed statement
        relationships = {}
        if parsed.predicate == "is_a":
            pass  # is_a goes into OWLEntity.is_a list
        elif parsed.predicate in ("part_of", "has_part", "instantiates",
                                   "embodies", "manifests", "reifies"):
            relationships[parsed.predicate] = [parsed.object]

        # Add additional predicates
        for pred, obj in parsed.additional:
            relationships.setdefault(pred, []).append(obj)

        # Extract EMR state from spiral if available
        emr_state = "embodies"  # default
        if spiral and spiral[0].reifies_via:
            emr_state = "reifies"
        elif spiral and spiral[0].embodies:
            emr_state = "manifests"

        # Build OWLEntity
        entity = OWLEntity(
            name=parsed.subject,
            description=f"{parsed.subject} {parsed.predicate} {parsed.object}",
            is_a=[parsed.object] if parsed.predicate == "is_a" else [],
            relationships=relationships,
            emr_state=emr_state,
        )

        # Write to both substrates (OWL + Carton queue)
        result = dual.add_entity(entity)

        if not result["owl_success"]:
            print(f"Warning: Failed to persist {parsed.subject} to domain OWL")

    except Exception as e:
        print(f"Warning: Persistence error for {parsed.subject}: {e}")


def _persist_to_soup(
    parsed: ParsedStatement,
    spiral: List[SpiralStep],
    break_point: Optional[str],
    whats_missing: List[str]
) -> Dict[str, Any]:
    """Persist incomplete chain to SOUP with Hallucination metadata.

    SOUP = "Some Ontology Under Production"
    Incomplete chains are puzzle pieces waiting for their edges.

    Args:
        parsed: The parsed statement
        spiral: The derivation spiral (partial)
        break_point: Where the chain breaks
        whats_missing: What edges are needed

    Returns:
        Hallucination metadata dict
    """
    from .uarl_validator import UARLValidator, ValidationResult, ValidationError

    # Build hallucination metadata
    # This captures the "shape" of the puzzle piece - what would complete it
    hallucination_meta = {
        "is_hallucination": True,
        "statement": parsed.raw,
        "subject": parsed.subject,
        "predicate": parsed.predicate,
        "object": parsed.object,
        "break_point": break_point,
        "whats_missing": whats_missing,
        "error_patterns": [f"{parsed.predicate}_unknown_target"],
        "evolution_target": parsed.object,  # The unknown thing that needs to be defined
        "would_need": [
            f"{parsed.object} is_a ?",
            f"{parsed.object} part_of ?",
            f"{parsed.object} instantiates ?"
        ],
        "spiral_state": [
            {
                "subject": s.subject,
                "predicate": s.predicate,
                "object": s.object,
                "is_placeholder": s.is_placeholder
            }
            for s in spiral
        ]
    }

    # Persist to SOUP via Carton queue
    # The SOUP layer is a holding area for incomplete concepts
    try:
        import os
        import json
        from pathlib import Path
        from datetime import datetime
        import uuid

        # Get queue directory from environment or default
        heaven_data = os.getenv('HEAVEN_DATA_DIR', '/tmp/heaven_data')
        soup_dir = Path(heaven_data) / "soup"
        soup_dir.mkdir(parents=True, exist_ok=True)

        # Create SOUP entry file
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        unique_id = str(uuid.uuid4())[:8]
        soup_file = soup_dir / f"{timestamp}_{unique_id}_hallucination.json"

        soup_entry = {
            "type": "Hallucination",
            "created_at": datetime.now().isoformat(),
            "metadata": hallucination_meta,
            # For promotion tracking
            "waiting_for": [parsed.object],  # Concepts that would complete this
            "promoted": False,
            "promoted_at": None
        }

        with open(soup_file, 'w') as f:
            json.dump(soup_entry, f, indent=2)

    except Exception as e:
        print(f"Warning: SOUP persistence error for {parsed.subject}: {e}")

    # NOTE: Carton queue write removed - Carton now calls YOUKNOW,
    # so YOUKNOW should NOT queue back (would cause duplicate entries).
    # The calling Carton add_concept_tool_func handles persistence with layer info.

    return hallucination_meta


