def _build_soup_response(
    response: CompilerResponse,
    spiral: List[SpiralStep],
    break_point: Optional[str],
    whats_missing: List[str]
) -> str:
    """Build SOUP response with derivation state and specific next-declaration.

    Format: SOUP:L{level}|{subject}@{break}|chain[n/m]|need[specific]|next:{action}

    This replaces _compress_soup_response which was a lossy regex parser
    that discarded derivation level, chain progress, and actionable guidance.
    """
    # Get subject and its derivation level from first spiral step
    subject = response.statement.split()[0] if response.statement else "?"
    level = 0

    if spiral:
        first_step = spiral[0]
        if first_step.derivation_level is not None:
            level = first_step.derivation_level.value

    # Chain progress: defined steps vs total
    defined_count = sum(1 for s in spiral if not s.is_placeholder)
    total_count = len(spiral) if spiral else 0

    # Find the break point step to get ITS specific derivation needs
    break_step = None
    for step in spiral:
        if step.subject == break_point:
            break_step = step
            break

    # Build need[] and next: from the break point's context
    if break_step and not break_step.is_placeholder and break_step.whats_missing_for_next_level:
        # Known entity with specific derivation gap — use derivation-level missing
        need_items = []
        for item in break_step.whats_missing_for_next_level:
            key = item.split(":")[0].strip() if ":" in item else item
            need_items.append(f"{break_point}.{key}")
        need_str = ",".join(need_items)
        first_key = break_step.whats_missing_for_next_level[0].split(":")[0].strip()
        next_action = f"declare {break_point} {first_key} ?"
    elif break_point:
        # Unknown entity (placeholder) — use chain-level whats_missing
        need_items = []
        for item in whats_missing:
            parts = item.split()
            if len(parts) >= 2:
                need_items.append(f"{parts[0]}.{parts[1]}")
        need_str = ",".join(need_items) if need_items else "?"
        next_action = f"declare {break_point} is_a ?"
    else:
        need_str = "?"
        next_action = "?"

    return f"SOUP:L{level}|{subject}@{break_point or '?'}|chain[{defined_count}/{total_count}]|need[{need_str}]|next:{next_action}"


def _compress_soup_response(
    parsed: ParsedStatement,
    whats_missing: List[str],
    break_point: Optional[str]
) -> str:
    """Compress SOUP response using symbol table for token efficiency.

    Instead of: "SOUP: Dog is_a Pet. Unknown: Pet is_a ? (unknown), Pet part_of ? (unknown)"
    Output:     "{1:Pet}|SOUP:?[1]need[is_a,part_of,inst]"

    The symbol table maps repeated entities to single-char keys.
    LLM attention can track via explicit mapping.
    """
    # Collect unique entities from whats_missing
    # Format: "Pet is_a ? (unknown)" -> extract "Pet"
    entities = set()
    missing_rels = set()

    for item in whats_missing:
        # Parse "Entity rel ? (unknown)" format
        parts = item.split()
        if len(parts) >= 2:
            entities.add(parts[0])
            if len(parts) >= 3:
                rel = parts[1]
                # Compress common relationship names
                rel_map = {"is_a": "isa", "part_of": "po", "instantiates": "inst"}
                missing_rels.add(rel_map.get(rel, rel))

    # Add break_point entity if not in entities
    if break_point and break_point not in entities:
        entities.add(break_point)

    # Build symbol table: {1:Entity1, 2:Entity2, ...}
    ent_list = sorted(entities)
    sym_table = {ent: str(i+1) for i, ent in enumerate(ent_list)}

    # Format symbol table
    if len(ent_list) == 1:
        table_str = f"{{1:{ent_list[0]}}}"
    else:
        table_str = "{" + ",".join(f"{i+1}:{e}" for i, e in enumerate(ent_list)) + "}"

    # Format missing relationships
    rels_str = ",".join(sorted(missing_rels)) if missing_rels else "?"

    # Compressed output
    ent_refs = ",".join(sym_table[e] for e in ent_list)
    return f"{table_str}|SOUP:?[{ent_refs}]need[{rels_str}]"


