@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix uarl: <http://sanctuary.ai/uarl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

# ============================================================
# UNIVERSAL OWL-DRIVEN SHACL ENFORCEMENT
#
# ONE shape that reads ALL owl:Restriction (someValuesFrom)
# from any class in the ontology and enforces them as closed-world
# constraints. New types only need OWL restrictions — SHACL
# enforcement is automatic. No more hand-writing shapes per type.
#
# How it works:
#   1. For each instance, find its rdf:type
#   2. Walk rdfs:subClassOf to find owl:Restriction entries
#   3. For each restriction with owl:someValuesFrom:
#      check that the instance HAS a value for that property
#      AND that value is typed as the required class
#   4. Report missing as Violation with human-readable message
#
# Replaces 22 hardcoded shapes (929 lines) with ~60 lines.
# ============================================================

uarl:UniversalRestrictionEnforcer
    a sh:NodeShape ;
    sh:targetClass uarl:Entity ;
    sh:name "Universal OWL Restriction Enforcer" ;
    sh:description "Reads OWL someValuesFrom restrictions and enforces them. Any type defined in OWL with restrictions gets automatic SHACL enforcement." ;
    sh:sparql [
        sh:message "{?typeLabel} requires {?propLabel} pointing to a {?reqLabel}." ;
        sh:severity sh:Violation ;
        sh:select """
PREFIX uarl: <http://sanctuary.ai/uarl#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

SELECT $this ?typeLabel ?propLabel ?reqLabel
WHERE {
    $this rdf:type ?type .
    ?type rdfs:subClassOf ?restriction .
    ?restriction rdf:type owl:Restriction .
    ?restriction owl:onProperty ?prop .
    ?restriction owl:someValuesFrom ?reqType .
    BIND(REPLACE(STR(?type), ".*#", "") AS ?typeLabel)
    BIND(REPLACE(STR(?prop), ".*#", "") AS ?propLabel)
    BIND(REPLACE(STR(?reqType), ".*#", "") AS ?reqLabel)
    FILTER NOT EXISTS {
        $this ?prop ?value .
        ?value rdf:type ?reqType .
    }
    FILTER(?type != owl:Thing)
}
""" ;
    ] .

# Also enforce minCardinality restrictions (e.g. must have at least 1 isA)
uarl:UniversalMinCardinalityEnforcer
    a sh:NodeShape ;
    sh:targetClass uarl:Entity ;
    sh:name "Universal OWL MinCardinality Enforcer" ;
    sh:description "Reads OWL minCardinality restrictions and enforces minimum property counts." ;
    sh:sparql [
        sh:message "{?typeLabel} requires at least {?minCount} value(s) for {?propLabel}." ;
        sh:severity sh:Violation ;
        sh:select """
PREFIX uarl: <http://sanctuary.ai/uarl#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT $this ?typeLabel ?propLabel ?minCount
WHERE {
    $this rdf:type ?type .
    ?type rdfs:subClassOf ?restriction .
    ?restriction rdf:type owl:Restriction .
    ?restriction owl:onProperty ?prop .
    ?restriction owl:minCardinality ?minCountRaw .
    BIND(xsd:integer(?minCountRaw) AS ?minCount)
    BIND(REPLACE(STR(?type), ".*#", "") AS ?typeLabel)
    BIND(REPLACE(STR(?prop), ".*#", "") AS ?propLabel)
    FILTER(?minCount > 0)
    FILTER NOT EXISTS {
        $this ?prop ?anyValue .
    }
    FILTER(?type != owl:Thing)
}
""" ;
    ] .

# ============================================================
# CORE SENTENCE CHAIN ENFORCER
#
# Checks which steps of the automorphic revelation chain exist.
# Each step is a morphism in the core sentence:
#   isA → partOf → instantiates → embodies (automorphism) →
#   produces → reifies → programs → partOf(Reality) = closes
#
# Missing ANY step = SOUP (weak compression).
# ALL steps present = strong compression → ONT admission.
#
# This replaces the Python derivation levels (L0-L6) in
# derivation.py with ontology-driven checking.
# ============================================================

uarl:CoreSentenceEnforcer
    a sh:NodeShape ;
    sh:targetClass uarl:Entity ;
    sh:name "Core Sentence (Pattern of X Derivation)" ;
    sh:description "Reports ALL missing core sentence predicates at once. Partial order — not linear. Property chains infer what can be inferred. What remains missing IS the state." ;
    sh:sparql [
        sh:message "{?entityLabel} is MISSING: [{?missing}]" ;
        sh:severity sh:Violation ;
        sh:select """
PREFIX uarl: <http://sanctuary.ai/uarl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

SELECT $this ?entityLabel (GROUP_CONCAT(DISTINCT ?missingPred; separator=", ") AS ?missing)
WHERE {
    BIND(REPLACE(STR($this), ".*#", "") AS ?entityLabel)
    {
        FILTER NOT EXISTS { $this uarl:isA ?v1 . }
        BIND("isA" AS ?missingPred)
    } UNION {
        FILTER NOT EXISTS { $this uarl:partOf ?v2 . }
        BIND("partOf" AS ?missingPred)
    } UNION {
        FILTER NOT EXISTS { $this uarl:produces ?v3 . }
        BIND("produces" AS ?missingPred)
    } UNION {
        FILTER NOT EXISTS { $this uarl:instantiates ?v4 . }
        BIND("instantiates" AS ?missingPred)
    } UNION {
        FILTER NOT EXISTS { $this uarl:embodies ?v5 . }
        BIND("embodies" AS ?missingPred)
    } UNION {
        FILTER NOT EXISTS { $this uarl:manifests ?v6 . }
        BIND("manifests" AS ?missingPred)
    } UNION {
        FILTER NOT EXISTS { $this uarl:reifies ?v7 . }
        BIND("reifies" AS ?missingPred)
    } UNION {
        FILTER NOT EXISTS { $this uarl:programs ?v8 . }
        BIND("programs" AS ?missingPred)
    }
}
GROUP BY $this ?entityLabel
HAVING (COUNT(DISTINCT ?missingPred) > 0)
""" ;
    ] .

# ============================================================
# COMPRESSION CLASSIFIER (SOUP vs ONT)
#
# Strong compression = ALL core sentence predicates present
#   AND all relationship targets ALSO have all predicates
#   AND entity has abstraction mapping to Cat (Aut closes)
# Weak compression = some predicates present but not all
#   OR targets don't have their predicates
# SOUP = weak compression. ONT = strong compression.
#
# This shape ONLY fires when entity has ALL 8 predicates
# but targets DON'T — meaning: "you're close but not ONT yet
# because your targets aren't strongly compressed"
# ============================================================

uarl:WeakCompressionDetector
    a sh:NodeShape ;
    sh:targetClass uarl:Entity ;
    sh:name "Weak Compression (SOUP — targets incomplete)" ;
    sh:description "Entity has all core sentence predicates but at least one target does not. Weak compression = SOUP." ;
    sh:sparql [
        sh:message "{?entityLabel} has WEAK compression: target {?targetLabel} (via {?propLabel}) is missing {?targetMissing}." ;
        sh:severity sh:Warning ;
        sh:select """
PREFIX uarl: <http://sanctuary.ai/uarl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

SELECT $this ?entityLabel ?propLabel ?targetLabel (GROUP_CONCAT(DISTINCT ?tMissing; separator=", ") AS ?targetMissing)
WHERE {
    $this uarl:isA ?v1 .
    $this uarl:partOf ?v2 .
    $this uarl:produces ?v3 .
    $this uarl:instantiates ?v4 .
    $this uarl:programs ?v5 .
    BIND(REPLACE(STR($this), ".*#", "") AS ?entityLabel)
    $this ?prop ?target .
    FILTER(?prop != rdf:type)
    FILTER(STRSTARTS(STR(?prop), "http://sanctuary.ai/uarl#"))
    BIND(REPLACE(STR(?prop), ".*#", "") AS ?propLabel)
    BIND(REPLACE(STR(?target), ".*#", "") AS ?targetLabel)
    {
        FILTER NOT EXISTS { ?target uarl:isA ?tv1 . }
        BIND("isA" AS ?tMissing)
    } UNION {
        FILTER NOT EXISTS { ?target uarl:partOf ?tv2 . }
        BIND("partOf" AS ?tMissing)
    } UNION {
        FILTER NOT EXISTS { ?target uarl:produces ?tv3 . }
        BIND("produces" AS ?tMissing)
    } UNION {
        FILTER NOT EXISTS { ?target uarl:programs ?tv5 . }
        BIND("programs" AS ?tMissing)
    }
}
GROUP BY $this ?entityLabel ?propLabel ?targetLabel
HAVING (COUNT(DISTINCT ?tMissing) > 0)
""" ;
    ] .

# ============================================================
# CAT ADMISSION CHECK (ONT gate)
#
# For an entity to be ONT (strong compression), it must:
# 1. Have ALL core sentence predicates (isA, partOf, produces,
#    instantiates, embodies, manifests, reifies, programs)
# 2. All targets also strongly compressed (recursive)
# 3. Have hasEWS pointing to a complete EWS
# 4. EWS has Abstraction mapping to Cat (has objects,
#    morphisms, identity, composition → has Aut → Domain)
#
# This shape fires when entity CLAIMS programs but doesn't
# have the Cat admission path.
# ============================================================

uarl:CatAdmissionCheck
    a sh:NodeShape ;
    sh:targetClass uarl:Entity ;
    sh:name "Cat Admission (ONT gate)" ;
    sh:description "Entity claims programs but has no EWS with Abstraction mapping to Cat. Cannot be admitted to ONT without Cat interpretation." ;
    sh:sparql [
        sh:message "{?entityLabel} claims programs but has no hasEWS. Cannot be ONT without EWS proving the abstraction maps to Cat." ;
        sh:severity sh:Warning ;
        sh:select """
PREFIX uarl: <http://sanctuary.ai/uarl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

SELECT $this ?entityLabel
WHERE {
    $this uarl:programs ?reality .
    BIND(REPLACE(STR($this), ".*#", "") AS ?entityLabel)
    FILTER NOT EXISTS { $this uarl:hasEWS ?ews . }
}
""" ;
    ] .

# ============================================================
# RECURSIVE JUSTIFICATION ENFORCER
#
# For every relationship this entity has, checks:
# 1. The target entity satisfies ITS OWL restrictions too (recursive)
# 2. The property is valid in the domain (has rdfs:domain/range or is declared)
#
# This is the MSC justification check — every relationship must be
# justified through the domain ontology, not just exist.
# ============================================================

uarl:RecursiveJustificationEnforcer
    a sh:NodeShape ;
    sh:targetClass uarl:Entity ;
    sh:name "Recursive Relationship Justification" ;
    sh:description "Every relationship target must itself satisfy its type restrictions. MSC = every relationship justified recursively." ;
    sh:sparql [
        sh:message "{?targetLabel} (target of {?propLabel} from {?sourceLabel}) is typed as {?targetTypeLabel} but is missing required {?missingPropLabel} pointing to {?missingReqLabel}." ;
        sh:severity sh:Violation ;
        sh:select """
PREFIX uarl: <http://sanctuary.ai/uarl#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

SELECT $this ?sourceLabel ?propLabel ?targetLabel ?targetTypeLabel ?missingPropLabel ?missingReqLabel
WHERE {
    $this ?prop ?target .
    ?target rdf:type ?targetType .
    ?targetType rdfs:subClassOf ?restriction .
    ?restriction rdf:type owl:Restriction .
    ?restriction owl:onProperty ?missingProp .
    ?restriction owl:someValuesFrom ?missingReqType .
    BIND(REPLACE(STR($this), ".*#", "") AS ?sourceLabel)
    BIND(REPLACE(STR(?prop), ".*#", "") AS ?propLabel)
    BIND(REPLACE(STR(?target), ".*#", "") AS ?targetLabel)
    BIND(REPLACE(STR(?targetType), ".*#", "") AS ?targetTypeLabel)
    BIND(REPLACE(STR(?missingProp), ".*#", "") AS ?missingPropLabel)
    BIND(REPLACE(STR(?missingReqType), ".*#", "") AS ?missingReqLabel)
    FILTER NOT EXISTS {
        ?target ?missingProp ?val .
        ?val rdf:type ?missingReqType .
    }
    FILTER(?targetType != owl:Thing)
    FILTER(?prop != rdf:type)
}
""" ;
    ] .

# ============================================================
# DOMAIN VALIDITY ENFORCER
#
# Checks that properties used on an entity are valid for its type.
# If a property has rdfs:domain, the entity must be of that domain.
# Catches: "you used ships on Goods but ships isn't in Goods Domain"
# ============================================================

uarl:DomainValidityEnforcer
    a sh:NodeShape ;
    sh:targetClass uarl:Entity ;
    sh:name "Domain Property Validity" ;
    sh:description "Properties must be valid for the entity's type domain." ;
    sh:sparql [
        sh:message "{?entityLabel} uses property {?propLabel} but {?propLabel} has domain {?domainLabel} which {?entityLabel} (typed as {?typeLabel}) is not part of." ;
        sh:severity sh:Warning ;
        sh:select """
PREFIX uarl: <http://sanctuary.ai/uarl#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

SELECT $this ?entityLabel ?propLabel ?domainLabel ?typeLabel
WHERE {
    $this ?prop ?anyVal .
    ?prop rdfs:domain ?domain .
    $this rdf:type ?type .
    BIND(REPLACE(STR($this), ".*#", "") AS ?entityLabel)
    BIND(REPLACE(STR(?prop), ".*#", "") AS ?propLabel)
    BIND(REPLACE(STR(?domain), ".*#", "") AS ?domainLabel)
    BIND(REPLACE(STR(?type), ".*#", "") AS ?typeLabel)
    FILTER NOT EXISTS {
        ?type rdfs:subClassOf* ?domain .
    }
    FILTER(?prop != rdf:type)
    FILTER(?type != owl:Thing)
    FILTER(!STRSTARTS(STR(?prop), STR(rdf:)))
    FILTER(!STRSTARTS(STR(?prop), STR(rdfs:)))
    FILTER(!STRSTARTS(STR(?prop), STR(owl:)))
}
""" ;
    ] .

