# # ============================================================
# # DERIVATION CHAIN: Core sentence shapes (SOUP → ONT path)
# # The spectral sequence: is_a → embodies(part_of) → manifests(produces) → reifies → programs
# # These shapes are checked ONLY when a concept is in SOUP (incomplete)
# # Complete concepts that hit ONT types skip these entirely
# # ============================================================

# # L0: Any is_a claim at all — entry to SOUP
# uarl:DerivationL0Shape
    # a sh:NodeShape ;
    # sh:targetClass uarl:Entity ;
    # sh:name "L0: Primitive is_a (SOUP entry)" ;
    # sh:description "Every entity must have at least one is_a claim. This is the entry point — you said X is_a Y." ;
    # sh:property [
        # sh:path uarl:isA ;
        # sh:minCount 1 ;
        # sh:name "is_a claim" ;
        # sh:message "L0 MISSING: No is_a claim exists. You must declare what this thing IS. Say: X is_a Y. This is the primitive claim that enters SOUP." ;
        # sh:severity sh:Violation ;
