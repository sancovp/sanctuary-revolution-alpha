<?xml version="1.0"?>
<rdf:RDF xmlns="http://sanctuary.ai/uarl#"
     xml:base="http://sanctuary.ai/uarl"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:uarl="http://sanctuary.ai/uarl#">

    <owl:Ontology rdf:about="http://sanctuary.ai/uarl">
        <rdfs:label>UARL v4 - Universal Axiomatic Reality Language</rdfs:label>
        <rdfs:comment>
UARL v4 extends v3 with Crystal Ball's structural types.

v3 defined:  SOUP/ONT, embodies/manifests/reifies/programs,
             PatternOfIsA, compression, boundedness, SES

v4 adds:     Crystal Ball coordinate space types as foundation entities.
             CB is not a domain — it IS a structural extension of UARL.
             CB_Concept subClassOf Entity gives all CB types derivation chains.

Why foundation not domain:
  CB is the generative substrate — it's how UARL does space-based reasoning.
  A "domain" would be Movies or Music. CB is the coordinate space itself.
  Just as PatternOfIsA is self-reifying, CB spaces are self-describing.
        </rdfs:comment>
        <owl:versionInfo>4.0.0 - Crystal Ball Structural Extension</owl:versionInfo>
    </owl:Ontology>

    <!-- ============================================================ -->
    <!-- EVERYTHING FROM v3 IS INHERITED (same namespace, same IRI)   -->
    <!-- Below are the NEW additions for v4                           -->
    <!-- ============================================================ -->

    <!-- ============================================== -->
    <!-- CB STRUCTURAL TYPES — coordinate space algebra -->
    <!-- ============================================== -->

    <owl:Class rdf:about="#CB_Concept">
        <rdfs:subClassOf rdf:resource="#Entity"/>
        <rdfs:label>CB_Concept</rdfs:label>
        <rdfs:comment>
Root of Crystal Ball's structural type system.
SubClassOf Entity — all CB types chain to Entity → Cat_of_Cat.
CB is not a domain; it IS a structural extension of UARL for
space-based coordinate reasoning.
        </rdfs:comment>
    </owl:Class>

    <!-- Space: the fundamental container -->
    <owl:Class rdf:about="#CB_Space">
        <rdfs:subClassOf rdf:resource="#CB_Concept"/>
        <rdfs:label>CB_Space</rdfs:label>
        <rdfs:comment>
A named container of nodes forming a tree.
Spaces can be composed (tensor product) or drilled into (produced spaces).
The space IS the solution space being explored.
        </rdfs:comment>
    </owl:Class>

    <!-- Node: a point in the tree -->
    <owl:Class rdf:about="#CB_Node">
        <rdfs:subClassOf rdf:resource="#CB_Concept"/>
        <rdfs:label>CB_Node</rdfs:label>
        <rdfs:comment>
A point in a space's tree. Has label, children, optional stratum.
Children ARE the spectrum — they define valid selections at this level.
        </rdfs:comment>
    </owl:Class>

    <!-- Coordinate: a path through the tree -->
    <owl:Class rdf:about="#CB_Coordinate">
        <rdfs:subClassOf rdf:resource="#CB_Concept"/>
        <rdfs:label>CB_Coordinate</rdfs:label>
        <rdfs:comment>
A path through the tree, encoded as a digit string (e.g. "1.3.2").
Each segment selects a child. Maps to a unique real number.
        </rdfs:comment>
    </owl:Class>

    <!-- ============================================== -->
    <!-- STRATA — maps to Y-layers                      -->
    <!-- This is the CB ↔ YOUKNOW bridge                -->
    <!-- ============================================== -->

    <owl:Class rdf:about="#CB_Stratum">
        <rdfs:subClassOf rdf:resource="#CB_Concept"/>
        <rdfs:label>CB_Stratum</rdfs:label>
        <rdfs:comment>
Ontological layer a node belongs to. 6 strata map to YOUKNOW Y-layers.
The stratum determines what EMR state a concept lives at.
        </rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#CB_Stratum_Universal">
        <rdfs:subClassOf rdf:resource="#CB_Stratum"/>
        <rdfs:label>universal</rdfs:label>
        <rdfs:comment>Stratum 1 — observation types. Y₁ Upper Ontology.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#CB_Stratum_Subclass">
        <rdfs:subClassOf rdf:resource="#CB_Stratum"/>
        <rdfs:label>subclass</rdfs:label>
        <rdfs:comment>Stratum 2 — subject buckets. Y₂ Domain. EMR: embodies.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#CB_Stratum_Instance">
        <rdfs:subClassOf rdf:resource="#CB_Stratum"/>
        <rdfs:label>instance</rdfs:label>
        <rdfs:comment>Stratum 3 — operations per domain. Y₃ Application. EMR: manifests.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#CB_Stratum_Instance_Universal">
        <rdfs:subClassOf rdf:resource="#CB_Stratum"/>
        <rdfs:label>instance_universal</rdfs:label>
        <rdfs:comment>Stratum 4 — actual things. Y₄ Instance. EMR: reifies.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#CB_Stratum_Instance_Subtype">
        <rdfs:subClassOf rdf:resource="#CB_Stratum"/>
        <rdfs:label>instance_subtype</rdfs:label>
        <rdfs:comment>Stratum 5 — patterns from instances. Y₅ Instance Type.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#CB_Stratum_Instance_Instance">
        <rdfs:subClassOf rdf:resource="#CB_Stratum"/>
        <rdfs:label>instance_instance</rdfs:label>
        <rdfs:comment>Stratum 6 — THE thing. Y₆ Implementation. EMR: programs.</rdfs:comment>
    </owl:Class>

    <!-- ============================================== -->
    <!-- LIFECYCLE PHASES                                -->
    <!-- ============================================== -->

    <owl:Class rdf:about="#CB_Phase">
        <rdfs:subClassOf rdf:resource="#CB_Concept"/>
        <rdfs:label>CB_Phase</rdfs:label>
        <rdfs:comment>A lifecycle phase: create → bloom → fill → lock → mine.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#CB_Phase_Create">
        <rdfs:subClassOf rdf:resource="#CB_Phase"/>
        <rdfs:label>create</rdfs:label>
        <rdfs:comment>Create a new space. Root node exists.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#CB_Phase_Bloom">
        <rdfs:subClassOf rdf:resource="#CB_Phase"/>
        <rdfs:label>bloom</rdfs:label>
        <rdfs:comment>
Add children to nodes. Build the spectrum.
THIS is where YOUKNOW feedback exponentiates options.
Each label feeds into youknow() → ideas become new children.
        </rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#CB_Phase_Fill">
        <rdfs:subClassOf rdf:resource="#CB_Phase"/>
        <rdfs:label>fill</rdfs:label>
        <rdfs:comment>Fill slot values from existing spectra.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#CB_Phase_Lock">
        <rdfs:subClassOf rdf:resource="#CB_Phase"/>
        <rdfs:label>lock</rdfs:label>
        <rdfs:comment>Lock a node — commit the spectrum. Requires ≥2 children.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#CB_Phase_Mine">
        <rdfs:subClassOf rdf:resource="#CB_Phase"/>
        <rdfs:label>mine</rdfs:label>
        <rdfs:comment>Enumerate all valid coordinate paths. Configuration space.</rdfs:comment>
    </owl:Class>

    <!-- ============================================== -->
    <!-- KERNEL, ORBIT, SPECTRUM, VIEW                  -->
    <!-- ============================================== -->

    <owl:Class rdf:about="#CB_Kernel">
        <rdfs:subClassOf rdf:resource="#CB_Concept"/>
        <rdfs:label>CB_Kernel</rdfs:label>
        <rdfs:comment>
A locked space. All nodes committed. Defines a group action:
which coordinates are equivalent under permutation of children.
        </rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#CB_Orbit">
        <rdfs:subClassOf rdf:resource="#CB_Concept"/>
        <rdfs:label>CB_Orbit</rdfs:label>
        <rdfs:comment>Equivalence class under kernel's symmetry group.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#CB_Spectrum">
        <rdfs:subClassOf rdf:resource="#CB_Concept"/>
        <rdfs:label>CB_Spectrum</rdfs:label>
        <rdfs:comment>The children of a node. Needs ≥2 elements (high and low).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#CB_View">
        <rdfs:subClassOf rdf:resource="#CB_Concept"/>
        <rdfs:label>CB_View</rdfs:label>
        <rdfs:comment>
A filter on a space — blacklist, whitelist, favorites.
Views are filters, not deletions. Different views = different symmetry groups.
        </rdfs:comment>
    </owl:Class>

    <!-- ============================================== -->
    <!-- CB RELATIONSHIPS                                -->
    <!-- ============================================== -->

    <owl:ObjectProperty rdf:about="#hasChild">
        <rdfs:subPropertyOf rdf:resource="#partOf"/>
        <rdfs:label>has_child</rdfs:label>
        <rdfs:comment>Parent-child in CB tree. Children = productive necessitations = the spectrum.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#producesSpace">
        <rdfs:label>produces_space</rdfs:label>
        <rdfs:comment>A node that drills into another space via registry.</rdfs:comment>
        <rdfs:domain rdf:resource="#CB_Node"/>
        <rdfs:range rdf:resource="#CB_Space"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#hasStratum">
        <rdfs:label>has_stratum</rdfs:label>
        <rdfs:comment>Assigns a node to a stratum (ontological layer).</rdfs:comment>
        <rdfs:domain rdf:resource="#CB_Node"/>
        <rdfs:range rdf:resource="#CB_Stratum"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#inPhase">
        <rdfs:label>in_phase</rdfs:label>
        <rdfs:comment>Current lifecycle phase of a space.</rdfs:comment>
        <rdfs:domain rdf:resource="#CB_Space"/>
        <rdfs:range rdf:resource="#CB_Phase"/>
    </owl:ObjectProperty>

</rdf:RDF>
