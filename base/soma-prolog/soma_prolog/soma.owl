  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">kernel_derive(EventId, Source, List)</hasRuleHead>
  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">(append([Obs], Rest, List), kernel_process_observation(EventId, Source, Obs), kernel_derive(EventId, Source, Rest))</hasRuleBody>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_kernel_process_observation_match">
