</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_kernel_derive_base">
  <rdf:type rdf:resource="#PrologRule"/>
  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">kernel_derive(_EventId, _Source, [])</hasRuleHead>
