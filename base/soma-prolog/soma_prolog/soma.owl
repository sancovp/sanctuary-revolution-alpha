</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#generatesMaker">
  <rdfs:domain rdf:resource="#TemplatedClass"/>
  <rdfs:range rdf:resource="#Maker"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A TemplatedClass generates a Maker that produces more of itself.
        Futamura 2nd projection.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#generatesTemplate">
  <rdfs:domain rdf:resource="#TemplatedClass"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A TemplatedClass generates a Jinja template OF ITSELF.
        Futamura 1st projection: object_to_template().</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasRenderMethod">
  <rdfs:domain rdf:resource="#RenderablePiece"/>
  <rdfs:range rdf:resource="#TemplateMethod"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The render() method. Every RenderablePiece has exactly one.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasPiece">
  <rdfs:domain rdf:resource="#MetaStack"/>
  <rdfs:range rdf:resource="#RenderablePiece"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ordered pieces in the stack. Rendered in sequence.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasFractalStage">
  <rdfs:domain rdf:resource="#FractalPattern"/>
  <rdfs:range rdf:resource="#FractalStage"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasSubstage">
  <rdfs:domain rdf:resource="#FractalStage"/>
  <rdfs:range rdf:resource="#FractalStage"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Recursive: a stage can contain substages.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#compilesTo">
  <rdfs:domain rdf:resource="#Process"/>
  <rdfs:range rdf:resource="#MetaStack"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Links a Process to the MetaStack it compiles into when it reaches CODE.
        Process(SOUP) → has no compilesTo.
        CodifiedProcess(TYPED) → compilesTo MetaStack (the SOP as structured output).
        ProgrammedProcess(CODE) → compilesTo FractalPattern (executable stages).</rdfs:comment>
</owl:ObjectProperty>

