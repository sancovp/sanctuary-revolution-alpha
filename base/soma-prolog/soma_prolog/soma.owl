<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://gnosys.ai/soma"
         xmlns="http://gnosys.ai/soma#">

<owl:Ontology rdf:about="http://gnosys.ai/soma">
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SOMA — Self-Organizing Meta-Architecture

        SOMA is_a TWILITELANG, constrained by TWI="Transforming the World Incorporated."

        Type hierarchy:
          Aut — the total self-referrable transformation set
          TWI — restriction class on Aut: "only these transformations are valid,
                because their meaning autologically reflects the decision to keep
                acting under these same constraints." (The bodhisattva vow pattern.)
                Subtypes are acronymic expansions of T-W-I.
          TWILITELANG — a language/system that encodes transformations under a TWI constraint.
          TWILITE — Language Instructing Twilitelang Encodings: the explanations/encodings
                    OF TWI. Everything has a TWILITE association (which is a PIOEntity).
          SOMA is_a TWILITELANG — specifically under TWI_Transforming_The_World_Incorporated.
               The business product IS a TWILITELANG whose constraint is "we are
               transforming the world as a business."

        The Prolog program running IS the business running.
        LLMs don't listen to rules. Prolog calls itself correctly or whines to the LLM.</rdfs:comment>
</owl:Ontology>

<owl:ObjectProperty rdf:about="#encodesConstraint">
  <rdfs:domain rdf:resource="#TWILITE"/>
  <rdfs:range rdf:resource="#TWI"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Which TWI constraint this TWILITE encoding explains.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#constrainedByTWI">
  <rdfs:domain rdf:resource="#TWILITELANG"/>
  <rdfs:range rdf:resource="#TWI"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Which TWI constraint this TWILITELANG operates under.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasCapability">
  <rdfs:domain rdf:resource="#OntologyEngineer"/>
  <rdfs:range rdf:resource="#Capability"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasRuleBase">
  <rdfs:domain rdf:resource="#PrologMI"/>
  <rdfs:range rdf:resource="#RuleBase"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasValue">
  <rdfs:domain rdf:resource="#Observation"/>
  <rdfs:range rdf:resource="#TypedValue"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasObservation">
  <rdfs:domain rdf:resource="#Event"/>
  <rdfs:range rdf:resource="#Observation"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#producedBy">
  <rdfs:domain rdf:resource="#Event"/>
  <rdfs:range rdf:resource="#Source"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#dispatchedBy">
  <rdfs:domain rdf:resource="#Dispatch"/>
  <rdfs:range rdf:resource="#PrologMI"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#dispatchedTo">
  <rdfs:domain rdf:resource="#Dispatch"/>
  <rdfs:range rdf:resource="#OntologyEngineer"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasSOP"/>

<owl:ObjectProperty rdf:about="#hasExecutableCode"/>

<owl:ObjectProperty rdf:about="#authorizedBy">
  <rdfs:domain rdf:resource="#ProgrammedProcess"/>
  <rdfs:range rdf:resource="#AuthorizedPersonnel"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Human authorization gate. CodifiedProcess → ProgrammedProcess
        ONLY when an AuthorizedPersonnel approves.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasSource">
  <rdfs:domain rdf:resource="#InteractionLoop"/>
  <rdfs:range rdf:resource="#Source"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasEngineer">
  <rdfs:domain rdf:resource="#InteractionLoop"/>
  <rdfs:range rdf:resource="#OntologyEngineer"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasMI">
  <rdfs:domain rdf:resource="#InteractionLoop"/>
  <rdfs:range rdf:resource="#PrologMI"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasReasoner">
  <rdfs:domain rdf:resource="#InteractionLoop"/>
  <rdfs:range rdf:resource="#PelletReasoner"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasGoal">
  <rdfs:domain rdf:resource="#Plan"/>
  <rdfs:range rdf:resource="#Goal"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasTWILITEAssociation">
  <rdfs:range rdf:resource="#TWILITE"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Everything has a TWILITE association — a PIOEntity mapping it
        to its TWI subtype. Domain is intentionally unset (applies to everything).</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#produces">
  <owl:inverseOf rdf:resource="#producedBy"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#observedIn">
  <rdfs:domain rdf:resource="#Process"/>
  <rdfs:range rdf:resource="#Event"/>
</owl:ObjectProperty>

