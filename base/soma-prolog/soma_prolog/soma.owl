  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">not((triple(C, is_a, giint_task), triple(C, part_of, P), not(triple(P, is_a, giint_deliverable))))</hasRuleBody>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#req_giint_task_parent">
