  <rdfs:range rdf:resource="#TemplateAttribute"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Which attributes this computed attribute depends on.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasStep">
  <rdfs:domain rdf:resource="#TemplateSequence"/>
  <rdfs:range rdf:resource="#TemplateMethod"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ordered steps in the sequence. OWL doesn't have native ordering
        so step order is encoded via hasStepIndex on each step.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasTemplateAttribute">
  <rdfs:domain rdf:resource="#TemplatedClass"/>
  <rdfs:range rdf:resource="#TemplateAttribute"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasTemplateMethod">
  <rdfs:domain rdf:resource="#TemplatedClass"/>
  <rdfs:range rdf:resource="#TemplateMethod"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasTemplateSequence">
  <rdfs:domain rdf:resource="#TemplatedClass"/>
  <rdfs:range rdf:resource="#TemplateSequence"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#makesInstanceOf">
  <rdfs:domain rdf:resource="#Maker"/>
  <rdfs:range rdf:resource="#TemplatedClass"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Which TemplatedClass this Maker creates instances of.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#configures">
  <rdfs:domain rdf:resource="#Configurator"/>
  <rdfs:range rdf:resource="#TemplatedClass"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">What this Configurator configures. Can include itself
