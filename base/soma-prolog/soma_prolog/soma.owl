</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_structure_preserving_match_fact">
  <rdf:type rdf:resource="#PrologRule"/>
  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">structure_preserving_match(Obs)</hasRuleHead>
  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">(rule(Head, _CF), compound(Head), structure_preserving_map(Obs, Head))</hasRuleBody>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_structure_preserving_map">
  <rdf:type rdf:resource="#PrologRule"/>
  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">structure_preserving_map(A, B)</hasRuleHead>
  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">(nonvar(A), nonvar(B), compound(A), compound(B), functor(A, F, Arity), functor(B, F, Arity), args_preserve_by_index(A, B, Arity))</hasRuleBody>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_args_preserve_by_index_base">
  <rdf:type rdf:resource="#PrologRule"/>
  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">args_preserve_by_index(_A, _B, 0)</hasRuleHead>
  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">true</hasRuleBody>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_args_preserve_by_index_step">
  <rdf:type rdf:resource="#PrologRule"/>
  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">args_preserve_by_index(A, B, N)</hasRuleHead>
  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">(succ(Prev, N), arg(N, A, ArgA), arg(N, B, ArgB), arg_preserves(ArgA, ArgB), args_preserve_by_index(A, B, Prev))</hasRuleBody>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_arg_preserves_identical">
