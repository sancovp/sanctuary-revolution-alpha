<owl:NamedIndividual rdf:about="#prolog_rule_validate_giint_component_parent">
  <rdf:type rdf:resource="#PrologRule"/>
  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">validate_giint_component_parent</hasRuleHead>
  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">not((triple(C, is_a, giint_component), triple(C, part_of, P), not(triple(P, is_a, giint_feature))))</hasRuleBody>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#req_giint_component_parent">
  <rdf:type rdf:resource="#CoreRequirement"/>
  <hasDeductionPremise rdf:datatype="http://www.w3.org/2001/XMLSchema#string">validate_giint_component_parent</hasDeductionPremise>
  <hasDeductionConclusion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">assertz(unmet_requirement(req_giint_component_parent))</hasDeductionConclusion>
  <hasDeductionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Every GIINT_Component must part_of a GIINT_Feature. If this fires, a component exists whose parent is not a feature.</hasDeductionDescription>
  <hasRequirementRemedy rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fix the part_of relationship on the GIINT_Component to point to a valid GIINT_Feature concept.</hasRequirementRemedy>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_validate_giint_feature_parent">
  <rdf:type rdf:resource="#PrologRule"/>
  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">validate_giint_feature_parent</hasRuleHead>
  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">not((triple(C, is_a, giint_feature), triple(C, part_of, P), not(triple(P, is_a, giint_project))))</hasRuleBody>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#req_giint_feature_parent">
  <rdf:type rdf:resource="#CoreRequirement"/>
  <hasDeductionPremise rdf:datatype="http://www.w3.org/2001/XMLSchema#string">validate_giint_feature_parent</hasDeductionPremise>
  <hasDeductionConclusion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">assertz(unmet_requirement(req_giint_feature_parent))</hasDeductionConclusion>
  <hasDeductionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Every GIINT_Feature must part_of a GIINT_Project.</hasDeductionDescription>
  <hasRequirementRemedy rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fix the part_of relationship on the GIINT_Feature to point to a valid GIINT_Project concept.</hasRequirementRemedy>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_validate_giint_deliverable_parent">
  <rdf:type rdf:resource="#PrologRule"/>
  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">validate_giint_deliverable_parent</hasRuleHead>
  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">not((triple(C, is_a, giint_deliverable), triple(C, part_of, P), not(triple(P, is_a, giint_component))))</hasRuleBody>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#req_giint_deliverable_parent">
  <rdf:type rdf:resource="#CoreRequirement"/>
  <hasDeductionPremise rdf:datatype="http://www.w3.org/2001/XMLSchema#string">validate_giint_deliverable_parent</hasDeductionPremise>
  <hasDeductionConclusion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">assertz(unmet_requirement(req_giint_deliverable_parent))</hasDeductionConclusion>
  <hasDeductionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Every GIINT_Deliverable must part_of a GIINT_Component.</hasDeductionDescription>
  <hasRequirementRemedy rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fix the part_of relationship on the GIINT_Deliverable to point to a valid GIINT_Component concept.</hasRequirementRemedy>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_validate_giint_task_parent">
