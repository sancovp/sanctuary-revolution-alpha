<owl:NamedIndividual rdf:about="#req_can_call_llm">
  <rdf:type rdf:resource="#CoreRequirement"/>
  <hasDeductionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SOMA must know that it can call an LLM. There must be a Prolog predicate proving it, and the OntologyEngineer class must have at least one Capability individual representing the call-LLM capability.</hasDeductionDescription>
  <hasDeductionPremise rdf:datatype="http://www.w3.org/2001/XMLSchema#string">requirement_can_call_llm</hasDeductionPremise>
  <hasDeductionConclusion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">assertz(unmet_requirement(req_can_call_llm))</hasDeductionConclusion>
  <hasRequirementRemedy rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Add a Prolog rule named requirement_can_call_llm whose body proves SOMA can call the LLM. Also create a Capability individual linked to OntologyEngineer via hasCapability whose label is "call_llm".</hasRequirementRemedy>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#req_authorization_reasoning">
  <rdf:type rdf:resource="#CoreRequirement"/>
  <hasDeductionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SOMA must reason about whether to call the LLM for any given gap, on the basis of authorization. For any unfilled property, SOMA must determine: can the LLM fill this, or does it need a real-world observation from a Source? If it requires reality, the LLM must not be the source.</hasDeductionDescription>
  <hasDeductionPremise rdf:datatype="http://www.w3.org/2001/XMLSchema#string">requirement_authorization_reasoning</hasDeductionPremise>
  <hasDeductionConclusion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">assertz(unmet_requirement(req_authorization_reasoning))</hasDeductionConclusion>
  <hasRequirementRemedy rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Add a Prolog rule named requirement_authorization_reasoning whose body proves that for any property an OntologyEngineer might fill, SOMA can decide whether the LLM is authorized or whether the value must come from a Source. The decision must be derivable from OWL annotations on the property, not hardcoded.</hasRequirementRemedy>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#req_failure_is_llm_call">
  <rdf:type rdf:resource="#CoreRequirement"/>
  <hasDeductionDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">When SOMA's core requirements are not met, the very first thing it emits is a structured failure error directed at the OntologyEngineer. The failure error names exactly which CoreRequirement is unmet, points at the requirement individual, and includes its remedy. The failure error IS the LLM call.</hasDeductionDescription>
  <hasDeductionPremise rdf:datatype="http://www.w3.org/2001/XMLSchema#string">requirement_failure_is_llm_call</hasDeductionPremise>
  <hasDeductionConclusion rdf:datatype="http://www.w3.org/2001/XMLSchema#string">assertz(unmet_requirement(req_failure_is_llm_call))</hasDeductionConclusion>
  <hasRequirementRemedy rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Add a Prolog rule named requirement_failure_is_llm_call whose body proves that the daemon transmits unmet_requirement assertions to the OntologyEngineer as a structured failure error. The rule must verify the failure-error format matches what the OntologyEngineer can read and act on.</hasRequirementRemedy>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#the_ontology_engineer">
  <rdf:type rdf:resource="#OntologyEngineer"/>
  <hasCapability rdf:resource="#cap_call_llm"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#cap_call_llm">
  <rdf:type rdf:resource="#Capability"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">call_llm</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_pellet_run">
  <rdf:type rdf:resource="#PrologRule"/>
  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">pellet_run</hasRuleHead>
  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">py_call('soma_prolog.utils':run_pellet(), _)</hasRuleBody>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_owl_save">
  <rdf:type rdf:resource="#PrologRule"/>
  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">owl_save</hasRuleHead>
  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">py_call('soma_prolog.utils':save_owl(), _)</hasRuleBody>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_persist_event">
  <rdf:type rdf:resource="#PrologRule"/>
  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">persist_event(Source, Observations, EventId)</hasRuleHead>
  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">(get_time(T), format(atom(EventId), 'evt_~f', [T]), format(atom(Timestamp), '~f', [T]), atom_string(EventId, EventIdStr), atom_string(Source, SourceStr), atom_string(Timestamp, TimestampStr), py_call('soma_prolog.utils':add_event_individual(EventIdStr, SourceStr, TimestampStr), _), forall(member(obs(Key, Value, Type), Observations), (atom_string(Key, KeyStr), (atom(Value) -&gt; atom_string(Value, ValueStr) ; format(string(ValueStr), '~w', [Value])), atom_string(Type, TypeStr), py_call('soma_prolog.utils':add_observation_individual(EventIdStr, KeyStr, ValueStr, TypeStr), _))))</hasRuleBody>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_build_report">
  <rdf:type rdf:resource="#PrologRule"/>
  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">build_report(EventId, Source, Observations, Report)</hasRuleHead>
  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">(length(Observations, ObsCount), format(atom(Report), 'event=~w source=~w observations=~w pellet=ok', [EventId, Source, ObsCount]))</hasRuleBody>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_requirement_can_call_llm">
  <rdf:type rdf:resource="#PrologRule"/>
  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">requirement_can_call_llm</hasRuleHead>
  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">py_call('soma_prolog.utils':check_requirement_can_call_llm(), _R)</hasRuleBody>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_requirement_authorization_reasoning">
  <rdf:type rdf:resource="#PrologRule"/>
  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">requirement_authorization_reasoning</hasRuleHead>
  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">py_call('soma_prolog.utils':check_requirement_authorization_reasoning(), _R)</hasRuleBody>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_requirement_failure_is_llm_call">
  <rdf:type rdf:resource="#PrologRule"/>
  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">requirement_failure_is_llm_call</hasRuleHead>
  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">py_call('soma_prolog.utils':check_requirement_failure_is_llm_call(), _R)</hasRuleBody>
