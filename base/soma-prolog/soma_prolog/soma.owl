</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_add_event">
  <rdf:type rdf:resource="#PrologRule"/>
  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">add_event(Source, Observations, Result)</hasRuleHead>
  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">(persist_event(Source, Observations, EventId), forall(member(Obs, Observations), assertz(event_observation(EventId, Obs))), forall(member(obs(Key, Value, Type), Observations), assertz(observation(EventId, Key, Value, Type))), forall(member(obs(authorize_compilation, AC, _), Observations), assertz(authorized_compilation(AC, Source))), process_event_partials(EventId), auto_compile_all(_CompileResults), owl_save, retractall(unmet_requirement(_)), fire_all_deduction_chains(Fired), length(Fired, NFired), findall(R, unmet_requirement(R), Unmet0), sort(Unmet0, Unmet), length(Unmet, NUnmet), build_report_with_chains(EventId, Source, Observations, NFired, NUnmet, Result))</hasRuleBody>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#prolog_rule_build_report_with_chains">
  <rdf:type rdf:resource="#PrologRule"/>
  <hasRuleHead rdf:datatype="http://www.w3.org/2001/XMLSchema#string">build_report_with_chains(EventId, Source, Observations, NFired, NUnmet, Report)</hasRuleHead>
  <hasRuleBody rdf:datatype="http://www.w3.org/2001/XMLSchema#string">(length(Observations, ObsCount), findall(UR, unmet_requirement(UR), Unmet), py_call('soma_prolog.utils':build_failure_error_report(Unmet), FailureStr), findall(T1-T2-T3, triple(T1, T2, T3), TripleList), length(TripleList, NTriples), findall(US1-US2-US3, unnamed_slot(US1, US2, US3), UnnamedList), length(UnnamedList, NUnnamedSlots), findall(CP, compiled_program(CP, _), CompiledList), length(CompiledList, NCompiled), format(atom(Report), 'event=~w source=~w observations=~w deduction_chains_fired=~w unmet=~w triples=~w unnamed_slots=~w compiled=~w~n~w', [EventId, Source, ObsCount, NFired, NUnmet, NTriples, NUnnamedSlots, NCompiled, FailureStr]))</hasRuleBody>
