@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix uarl: <http://sanctuary.ai/uarl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# ============================================================
# UARL SHACL CONSTRAINTS
# Closed-world validation for the UARL derivation chain
# ============================================================

# ============================================================
# PIOEntity - Foundation grounding anchor
# ============================================================

uarl:PIOEntityShape
    a sh:NodeShape ;
    sh:targetClass uarl:PIOEntity ;
    sh:name "PIOEntity Foundation Anchor" ;
    sh:description "PIOEntity is hallucination-in-reality: instantiates Metaphor and carries partial isomorphic self-claims." ;
    sh:class uarl:Hallucination ;
    sh:class uarl:Reality ;
    sh:property [
        sh:path uarl:instantiates ;
        sh:minCount 1 ;
        sh:class uarl:Metaphor ;
        sh:name "instantiates metaphor" ;
        sh:message "PIOEntity must instantiate Metaphor." ;
        sh:severity sh:Violation ;
    ] ;
    sh:property [
        sh:path uarl:hasPartialIsomorphicPattern ;
        sh:minCount 1 ;
        sh:class uarl:PartialIsomorphicPattern ;
        sh:name "partial isomorphic pattern" ;
        sh:message "PIOEntity must link at least one PartialIsomorphicPattern." ;
        sh:severity sh:Violation ;
    ] ;
    sh:property [
        sh:path uarl:hasSelfClaim ;
        sh:minCount 1 ;
        sh:class uarl:ClaimAboutSelf ;
        sh:name "self claim" ;
        sh:message "PIOEntity must include at least one claim about what it is." ;
        sh:severity sh:Violation ;
    ] .

# ============================================================
# EmbodimentClaim - Must have all 4 bridge components
# ============================================================

uarl:EmbodimentClaimShape
    a sh:NodeShape ;
    sh:targetClass uarl:EmbodimentClaim ;
    sh:name "Embodiment Claim Validation" ;
    sh:description "A valid EmbodimentClaim must have all 4 bridge components: intuition, compareFrom, mapsTo, analogicalPattern" ;
    
    # MUST have intuition (A)
    sh:property [
        sh:path uarl:intuition ;
        sh:minCount 1 ;
        sh:name "intuition (A)" ;
        sh:message "EmbodimentClaim is missing 'intuition' (A) - what are you thinking about? Structure: A with B embodies C wrt D" ;
        sh:severity sh:Violation ;
    ] ;
    
    # MUST have compareFrom (B)
    sh:property [
        sh:path uarl:compareFrom ;
        sh:minCount 1 ;
        sh:name "compareFrom (B)" ;
        sh:message "EmbodimentClaim is missing 'compareFrom' (B) - what are you comparing your intuition from? Structure: A with B embodies C wrt D" ;
        sh:severity sh:Violation ;
    ] ;
    
    # MUST have mapsTo (C)
    sh:property [
        sh:path uarl:mapsTo ;
        sh:minCount 1 ;
        sh:name "mapsTo (C)" ;
        sh:message "EmbodimentClaim is missing 'mapsTo' (C) - where does the pattern map to? Structure: A with B embodies C wrt D" ;
        sh:severity sh:Violation ;
    ] ;
    
    # MUST have analogicalPattern (D)
    sh:property [
        sh:path uarl:analogicalPattern ;
        sh:minCount 1 ;
        sh:name "analogicalPattern (D)" ;
        sh:message "EmbodimentClaim is missing 'analogicalPattern' (D) - this is THE ACTUAL PATTERN being discovered! Without it, you haven't completed the embodies step. Did you manifest enough to discover the pattern?" ;
        sh:severity sh:Violation ;
    ] .

# ============================================================
# PatternLattice - Must have abstraction level
# ============================================================

uarl:PatternLatticeShape
    a sh:NodeShape ;
    sh:targetClass uarl:PatternLattice ;
    sh:name "Pattern Lattice Validation" ;
    sh:description "A PatternLattice must have an abstraction level to position it in the lattice hierarchy" ;
    
    sh:property [
        sh:path uarl:abstractionLevel ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:name "abstraction level" ;
        sh:message "PatternLattice is missing 'abstractionLevel'. How abstract is this pattern? Higher = more general, lower = more specific. Set an integer value." ;
        sh:severity sh:Violation ;
    ] .

# ============================================================
# ValidatedLattice - Must instantiate pattern_of_is_a + have subsumes
# ============================================================

uarl:ValidatedLatticeShape
    a sh:NodeShape ;
    sh:targetClass uarl:ValidatedLattice ;
    sh:name "Validated Lattice Requirements" ;
    sh:description "A ValidatedLattice must instantiate pattern_of_is_a and have at least one subsumes relationship" ;
    
    # Must instantiate pattern_of_is_a
    sh:property [
        sh:path uarl:instantiates ;
        sh:minCount 1 ;
        sh:class uarl:PatternOfIsA ;
        sh:name "instantiates pattern_of_is_a" ;
        sh:message "ValidatedLattice does not 'instantiate' pattern_of_is_a. Your lattice structure must replicate the bootstrap pattern: is_a, part_of, and instantiates co-arise. Show how your pattern replicates this." ;
        sh:severity sh:Violation ;
    ] ;
    
    # Must have at least one subsumes (non-trivial lattice)
    sh:property [
        sh:path uarl:subsumes ;
        sh:minCount 1 ;
        sh:name "subsumes relationship" ;
        sh:message "ValidatedLattice has no 'subsumes' relationships. A lattice needs at least one level of abstraction - an abstract pattern that subsumes specific instances. Add subsumes relationships from abstract to specific." ;
        sh:severity sh:Violation ;
    ] .

# ============================================================
# GroundedLattice - Must be part_of Reality
# ============================================================

uarl:GroundedLatticeShape
    a sh:NodeShape ;
    sh:targetClass uarl:GroundedLattice ;
    sh:name "Grounded Lattice Requirements" ;
    sh:description "A GroundedLattice must have its root connected to Reality via part_of" ;
    
    sh:property [
        sh:path uarl:partOf ;
        sh:minCount 1 ;
        sh:class uarl:Reality ;
        sh:name "grounded in Reality" ;
        sh:message "GroundedLattice is not connected to Reality. The abstract root of your lattice must be 'part_of' something already in Reality. This is what grounds your pattern - connect it to existing validated ontology." ;
        sh:severity sh:Violation ;
    ] .

# ============================================================
# PROMOTION CHECK: Can this go from Soup to Ont?
# ============================================================

uarl:PatternOfIsAStrongCompressionShape
    a sh:NodeShape ;
    sh:targetClass uarl:PatternOfIsA ;
    sh:name "PatternOfIsA Strong Compression Requirements" ;
    sh:description "PatternOfIsA must be strongly compressed, bounded, and high SES depth before promotion" ;

    sh:property [
        sh:path uarl:hasMSC ;
        sh:minCount 1 ;
        sh:class uarl:MinimumSufficientCompression ;
        sh:name "has MSC" ;
        sh:message "PatternOfIsA is missing hasMSC -> MinimumSufficientCompression proof." ;
        sh:severity sh:Violation ;
    ] ;

    sh:property [
        sh:path uarl:justifies ;
        sh:minCount 1 ;
        sh:class uarl:DerivationJustification ;
        sh:name "justifies coverage" ;
        sh:message "PatternOfIsA is missing derivation justifications. Every required relation must be justified." ;
        sh:severity sh:Violation ;
    ] ;

    sh:property [
        sh:path uarl:catOfCatBounded ;
        sh:minCount 1 ;
        sh:datatype xsd:boolean ;
        sh:hasValue true ;
        sh:name "cat-of-cat bounded" ;
        sh:message "PatternOfIsA must explicitly assert catOfCatBounded=true for promotion." ;
        sh:severity sh:Violation ;
    ] ;

    sh:property [
        sh:path uarl:sesTypedDepth ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 6 ;
        sh:name "SES typed depth" ;
        sh:message "PatternOfIsA requires sesTypedDepth >= 6 (maximized programs threshold)." ;
        sh:severity sh:Violation ;
    ] ;

    sh:property [
        sh:path uarl:programs ;
        sh:minCount 1 ;
        sh:class uarl:Reality ;
        sh:name "programs reality" ;
        sh:message "PatternOfIsA must programs -> Reality for ONT admission." ;
        sh:severity sh:Violation ;
    ] .

uarl:PromotionReadyShape
    a sh:NodeShape ;
    sh:targetClass uarl:PatternOfIsA ;
    sh:name "Ready for Promotion to Reality" ;
    sh:description "Checks if PatternOfIsA is strongly compressed, bounded, and programs into Reality" ;
    
    # Must have completed the full chain
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "PatternOfIsA is not promotion-ready. Required: hasMSC, justifies coverage, catOfCatBounded=true, sesTypedDepth>=6, compressionMode='strong', and programs->Reality." ;
        sh:prefixes [
            sh:declare [
                sh:prefix "uarl" ;
                sh:namespace "http://sanctuary.ai/uarl#"^^xsd:anyURI ;
            ]
        ] ;
        sh:select """
            SELECT $this
            WHERE {
                $this a uarl:PatternOfIsA .
                FILTER (
                    NOT EXISTS { $this uarl:hasMSC ?msc . ?msc a uarl:MinimumSufficientCompression . } ||
                    NOT EXISTS { $this uarl:justifies ?j . ?j a uarl:DerivationJustification . } ||
                    NOT EXISTS { $this uarl:catOfCatBounded true } ||
                    NOT EXISTS { $this uarl:sesTypedDepth ?d . FILTER(?d >= 6) } ||
                    NOT EXISTS { $this uarl:compressionMode "strong" } ||
                    NOT EXISTS { $this uarl:programs ?r . ?r a uarl:Reality . }
                )
            }
        """ ;
    ] .

# ============================================================
# HALLUCINATION TYPING: Why did something fail?
# ============================================================

uarl:HallucinationExplainabilityShape
    a sh:NodeShape ;
    sh:targetClass uarl:Hallucination ;
    sh:name "Hallucination Explainability" ;
    sh:description "Hallucinations should have error explanations" ;
    
    sh:property [
        sh:path uarl:errorPattern ;
        sh:minCount 1 ;
        sh:name "error pattern" ;
        sh:message "Hallucination is missing 'errorPattern'. What pattern of mistake does this represent? Document it for the SOUP pattern analysis." ;
        sh:severity sh:Warning ;
    ] ;
    
    sh:property [
        sh:path uarl:whatsMissing ;
        sh:minCount 1 ;
        sh:name "what's missing" ;
        sh:message "Hallucination is missing 'whatsMissing'. What would need to be added for this to become Reality? Provide actionable guidance." ;
        sh:severity sh:Warning ;
    ] .

# ============================================================
# Requires_Evolution metadata
# ============================================================

uarl:RequiresEvolutionReasonShape
    a sh:NodeShape ;
    sh:targetClass uarl:Requires_Evolution ;
    sh:name "Requires_Evolution reason" ;
    sh:description "Requires_Evolution links should include explicit reason text" ;

    sh:property [
        sh:path uarl:reason ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:name "reason" ;
        sh:message "Requires_Evolution is missing reason text describing what must change." ;
        sh:severity sh:Warning ;
    ] .
