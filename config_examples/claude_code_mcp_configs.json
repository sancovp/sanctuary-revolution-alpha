{
  "mcpServers": {
    "gnosys_kit": {
      "command": "python3",
      "args": [
        "-m",
        "gnosys_treeshell.mcp_server.user_server"
      ],
      "env": {}
    },
    "skill_manager_treeshell": {
      "command": "python3",
      "args": [
        "-m",
        "skillmanager_treeshell.mcp_server.user_server"
      ],
      "env": {
        "HEAVEN_DATA_DIR": "__FILL_IN_YOUR_PATH__"
      }
    },
    "Context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "enabled": true
    },
    "autopoiesis": {
      "command": "autopoiesis-mcp",
      "args": []
    },
    "carton": {
      "type": "stdio",
      "command": "carton-mcp",
      "args": [],
      "env": {
        "GITHUB_PAT": "__YOUR_GITHUB_PAT__",
        "REPO_URL": "https://github.com/__YOUR_USERNAME__/__YOUR_WIKI_REPO__",
        "HEAVEN_DATA_DIR": "__FILL_IN_YOUR_PATH__",
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USER": "neo4j",
        "NEO4J_PASSWORD": "__YOUR_NEO4J_PASSWORD__",
        "OPENAI_API_KEY": "__YOUR_OPENAI_API_KEY__",
        "CHROMA_PERSIST_DIR": "__YOUR_CHROMA_PATH__"
      },
      "enabled": false
    }
  }
}
